@model EraasoftAcademy.Models.Quiz
<div class="row g-0">
    <div class="col-lg-8 pe-lg-2">
        <div class="card mb-3">
            <div class="card-header bg-body-tertiary">
                <h6 class="mb-0">Basic information</h6>
            </div>
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="card-body">
                <form method="post" enctype="multipart/form-data">
                    <div class="card mb-3">
                        <div class="card-body">
                            <div class="row flex-between-center">
                                <div class="col-md">
                                    <h5 class="mb-2 mb-md-0">Add a Quiz</h5>
                                </div>
                                <div class="col-auto">
                                    <a href="/Admin/Quiz/Index" class="btn btn-danger">Discard</a>

                                    <button class="btn btn-primary" role="button" type="submit">Add Quiz</button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row gx-2">
                        <div class="col-12 mb-3">
                            <label asp-for="Title" class="form-label"></label>
                            <input asp-for="Title" class="form-control" id="Title" type="text" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>
                        <div class="col-12 mb-3">

                            <label class="form-label" asp-for="Description"></label>
                            <textarea class="form-control"
                                      asp-for="Description"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                        <div class="col-12 mb-3">
                            <label class="form-label" asp-for="TotalMarks"></label>
                            <input class="form-control" asp-for="TotalMarks">
                            <span asp-validation-for="TotalMarks" class="text-danger"></span>
                        </div>
                        <div class="col-12 mb-3">
                            <label class="form-label" asp-for="Duration"></label>
                            <input class="form-control" asp-for="Duration" type="time">
                            <span asp-validation-for="Duration" class="text-danger"></span>
                        </div>
                        <div class="col-12 mb-3">
                            <div class="form-check form-switch">
                                <label class="form-check-label" asp-for="IsActive">Active Status</label>
                                <input class="form-check-input" asp-for="IsActive" type="checkbox">
                            </div>
                            <span asp-validation-for="IsActive" class="text-danger"></span>
                        </div>
                        
                        <div class="col-sm-6 mb-3">
                            <label class="form-label" asp-for="CourseId">Course</label>
                            <select class="form-select" asp-for="CourseId">
                                <option>Select course</option>
                                @if (ViewBag.Courses != null)
                                {
                                    foreach (var item in ViewBag.Courses)
                                    {
                                        <option value="@item.Course_Id">@item.Course_Name</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="CourseId" class="text-danger"></span>

                        </div>
                    </div>
                </form>
            </div>
        </div>


    </div>

</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>

}