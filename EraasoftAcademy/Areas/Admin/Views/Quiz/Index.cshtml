@using EraasoftAcademy.ViewModel
@model QuizVM
<div class="row">
    <div class="col-12">
        <div class="card h-lg-100 overflow-hidden">
            <div class="card-body p-0">
                <div class="card-footer bg-light py-2">
                    <div class="row flex-between-center">
                        <div class="col-auto">
                            <a class="btn btn-sm btn-success me-1"
                               href="@Url.Action("Create", "Quiz", new { area = "Admin" })">
                                ADD
                            </a>
                        </div>
                    </div>
                </div>

                <div class="table-responsive scrollbar">
                    <table class="table table-bordered mb-0 fs--1 border-200 align-middle text-center">


                        <thead class="bg-light">
                            <tr class="text-900 text-center">
                                <th style="width:15%">Title</th>
                                <th style="width:20%">Description</th>
                                <th style="width:7%">TotalMarks</th>
                                <th style="width:15%">QuizCode</th>
                                <th style="width:10%">Course</th>
                                <th style="width:8%">IsActive</th>
                                <th style="width:25%">Options</th>
                            </tr>
                        </thead>


                        <tbody>
                            @foreach (var item in Model.QuizList)
                            {
                                <tr class="border-bottom border-200">

                                    <td>
                                        <h6 class="mb-0 fw-semi-bold">
                                            @item.Title
                                        </h6>
                                    </td>

                                    <td>
                                        <h6 class="mb-0 fw-semi-bold">
                                            @item.Description
                                        </h6>
                                    </td>

                                    <td>
                                        <h6 class="mb-0 fw-semi-bold">
                                            @item.TotalMarks
                                        </h6>
                                    </td>

                                    <td>
                                        <h6 class="mb-0 fw-semi-bold">
                                            @item.QuizCode
                                        </h6>
                                    </td>

                                    <td>
                                        <h6 class="mb-0 fw-semi-bold">
                                            @item.Course.Course_Name
                                            
                                        </h6>
                                    </td>
                                    <td>
                                        <h6 class="mb-0 fw-semi-bold">
                                            @if (item.IsActive)
                                            {
                                                <i class="fa fa-check text-success"></i>
                                            }
                                            else
                                            {
                                                <i class="fa fa-times text-danger"></i>
                                            }
                                        </h6>
                                    </td>

                                    <td>
                                        <div class="d-flex justify-content-center gap-2 flex-wrap">

                                            <a class="btn btn-sm btn-outline-info"
                                               href="@Url.Action("QuestionList", "Quiz", new { id = item.Id, area = "Admin" })">
                                                <i class="fas fa-question-circle me-1"></i> Questions
                                            </a>

                                            <a class="btn btn-sm btn-outline-primary"
                                               href="@Url.Action("Edit", "Quiz", new { id = item.Id, area = "Admin" })">
                                                <i class="fas fa-edit me-1"></i> Edit
                                            </a>

                                            <a href="/Admin/Quiz/Delete/@item.Id"
                                               class="btn btn-sm btn-outline-danger btn-delete">
                                                <i class="fas fa-trash-alt me-1"></i> Delete
                                            </a>

                                        </div>
                                    </td>

                                </tr>
                            }
                        </tbody>

                    </table>
                </div>

            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const deleteButtons = document.querySelectorAll(".btn-delete");

        deleteButtons.forEach(button => {
            button.addEventListener("click", function (e) {
                e.preventDefault();

                const url = this.getAttribute("href");

                Swal.fire({
                    title: "Are you sure?",
                    text: "This action cannot be undone!",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonColor: "#d33",
                    cancelButtonColor: "#3085d6",
                    confirmButtonText: "Yes, delete it!"
                }).then((result) => {
                    if (result.isConfirmed) {
                        Swal.fire({
                            title: "Deleted!",
                            text: "Item deleted successfully.",
                            icon: "success",
                            timer: 1200,
                            showConfirmButton: false
                        }).then(() => {
                            window.location.href = url;
                        });
                    }
                });
            });
        });
    });
</script>